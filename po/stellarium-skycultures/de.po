msgid "ὄνος (Ass) I"
msgstr "ὄνος (Esel) I"

msgid ""
"The northernmost of the rear 2 stars on the quadrilateral, which are called "
"'Aselli'"
msgstr ""
"Der nördlichste der beiden hinteren Sterne des Vierecks, die »Aselli« "
"genannt werden"

msgid "ὄνος (Ass) II"
msgstr "ὄνος (Esel) II"

msgid "The northernmost of the 3 stars in the neck"
msgstr "Der nördlichste der drei Sterne im Nacken"

msgid "βασιλίσκος (Princelet)"
msgstr "βασιλίσκος (Prinzchen)"

msgid "The star on the heart, called 'Regulus'"
msgstr "Der Stern im Herzen, genannt „Regulus“"

msgid "The star a little in advance of the star on the heart [no. 8]"
msgstr "Der Stern ein bisschen vor dem Stern im Herzen [Nr. 8]"

msgid "The northernmost of the other, rearmost 2"
msgstr "Der nördlichster der anderen, der hintere der beiden"

msgid "The northernmost of the 2 stars in the buttocks"
msgstr "Der nördlichste der beiden Sterne im Gesäß"

msgid "The more advanced of the 2 over the back"
msgstr "Der vordere der beiden über dem Rücken"

msgid "The northernmost of the 3 under the flank"
msgstr "Der nördlichste der drei Sterne unter der Flanke"

msgid "The southernmost of the 2 stars in the top of the skull"
msgstr "Der südlichste der beiden Sterne in der Schädelspitze"

msgid "The northernmost of the 2 stars to the rear of these, in the face"
msgstr "Der nördlichste der beiden Sterne hinter diesen im Gesicht"

msgid "The most advanced of the 4 stars in the left wing"
msgstr "Der vorderste der vier Sterne im linken Flügel"

msgid "The most advanced of the 3 stars in the right, northern wing"
msgstr "Der vorderste der drei Sterne im rechten, nördlichen Flügel"

msgid "The southernmost of the other 2"
msgstr "Der südlichste der anderen beiden"

msgid "Προτρυγητήρ (Harbinger of Vintage)"
msgstr "Προτρυγητήρ (Vorbote der Weinlese)"

msgid "στάχυς (Ear of Grain)"
msgstr "στάχυς (Ähre)"

msgid "The star on the left hand, called 'Spica'"
msgstr "Der Stern auf der linken Hand genannt »Spica«"

