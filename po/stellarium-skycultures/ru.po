msgid "Bat"
msgstr "Летучая мышь"

msgid "Owl"
msgstr "Сова"

msgid "Vulture"
msgstr "Стервятник"

msgid "Death"
msgstr "Смерть"

msgid "Jaguar"
msgstr "Ягуар"

msgid "Toad"
msgstr "Жаба"

msgid "Single Star"
msgstr "Одинокая звезда"

msgid "Two brilliant ones"
msgstr "Пара сияющих"

msgid "Corner Star"
msgstr "Угловая звезда"

