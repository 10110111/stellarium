# Anutan constellation, native: Te Kope
msgid "The Bamboo"
msgstr "대나무"

# Description of Anutan constellation The Bamboo
msgid ""
"Bamboo is used to make fishing poles, sailing masts, yards, booms, and "
"outrigger supports."
msgstr "대나무는 낚싯대, 돛대, 야드, 붐 및 아우트리거 지지대를 만드는 데 사용됩니다."

# Anutan constellation, native: Ara Toru
msgid "Path of Three"
msgstr "삼의 길"

# Anutan constellation, native: Manu
msgid "Bird of Flight"
msgstr "비행의 새"

# Description of Anutan constellation Bird of Flight
msgid "The dominant constellation for Anutans. It can be seen in all seasons."
msgstr "Anutans의 지배적인 별자리. 사계절 내내 볼 수 있습니다."

# Anutan constellation, native: Te Angaanga
msgid "The Tongs"
msgstr "집게"

# Description of Anutan constellation The Tongs
msgid "Used for moving hot stones, coals, and food in an oven."
msgstr "오븐에서 뜨거운 돌, 석탄, 음식을 옮길 때 사용합니다."

# Anutan constellation, native: Kaavei
msgid "Octopus Tentacle"
msgstr "문어 촉수"

# Anutan constellation, native: Taki Mua
msgid "Forward Precursor"
msgstr "순방향 전구체"

# Anutan constellation, native: Toki
msgid "Adze"
msgstr "까뀌"

# Description of Anutan constellation Adze
msgid "Used for cutting canoes and building houses."
msgstr "카누를 자르고 집을 짓는 데 사용됩니다."

# Anutan constellation, native: Te Aamonga
msgid "The Carrying Stick"
msgstr "휴대용 스틱"

# Description of Anutan constellation The Carrying Stick
msgid "Used to carry taro, coconuts, or other food."
msgstr "토란, 코코넛 또는 기타 음식을 운반하는 데 사용됩니다."

# Anutan constellation, native: Te Paka Poi Ika Tapu
msgid "Crevalle-like Fish"
msgstr "크레발 같은 물고기"

# Description of Anutan constellation Crevalle-like Fish
msgid "Marked as uncertain."
msgstr "불확실한 것으로 표시됩니다."

# Anutan constellation, native: Taro
msgid "Taro Plant"
msgstr "타로공장"

# Anutan constellation, native: Te Kupenga
msgid "The Net"
msgstr "그물"

# Name for NAME Sirius
msgid "The Bird's Body"
msgstr "새의 몸"

# Name for NAME Canopus
msgid "The East Wing"
msgstr "이스트 윙"

# Name for NAME Procyon
msgid "The North Wing"
msgstr "노스 윙"

# Name for NAME Antares
msgid "Its Stem"
msgstr "줄기"

# Name for HIP 32607
msgid "The East Wing's Precursor"
msgstr "동쪽 날개의 선구자"

# Name for HIP 677
msgid "Middle Precursor"
msgstr "중간 전구체"

# Name for NAME Pleiades
msgid "Small Face"
msgstr "작은 얼굴"

# Name for NAME Large Magellanic Cloud
msgid "The Running Cloud"
msgstr "달리는 구름"

# Name for NAME Small Magellanic Cloud
msgid "The Restrained Cloud"
msgstr "억제된 구름"

# Name for NAME Venus
msgid "The Morning Star"
msgstr "모닝스타"

# Name for NAME Venus
msgid "The Evening Star"
msgstr "저녁 별"

# Arabic (Al-Sufi) constellation, native: الضباع وأولاد الضباع
msgid "The hyenas and their youngsters"
msgstr "하이에나와 그들의 젊은이들"

# Arabic (Al-Sufi) constellation, native: السفينة
msgid "Argo Navis"
msgstr "아르고 나비스"

# Arabic (Al-Sufi) constellation, native: فرس الصوفي
msgid "The horse"
msgstr "말"

# Arabic (Al-Sufi) constellation, native: الحوت العظيم
msgid "The great fish"
msgstr "큰 물고기"

# Arabic (Al-Sufi) constellation, native: الحوت الآخر
msgid "The other fish"
msgstr "다른 물고기들"

# Name for HIP 11767
msgid "The kid"
msgstr "아이"

# Name for HIP 72607
msgid "The brighter of the two calves"
msgstr "두 송아지 중 더 밝은"

# Name for HIP 75097
msgid "The dimmer of the two calves"
msgstr "두 송아지의 조광기"

# Name for HIP 62956
msgid "The dark camel"
msgstr "검은 낙타"

# Name for HIP 65378
msgid "The little goat"
msgstr "작은 염소"

# Name for HIP 67301
msgid "The leader"
msgstr "리더"

# Name for HIP 63125
msgid "Liver of the lion"
msgstr "사자의 간"

# Name for HIP 75458
msgid "The male hyena"
msgstr "수컷 하이에나"

# Name for HIP 69673
msgid "The high one with the spear"
msgstr "창을 든 높은 사람"

# Name for HIP 76267
msgid "The bright star of al-Fakkah"
msgstr "알-파카의 밝은 별"

# Name for HIP 84345
msgid "Head of Hercules"
msgstr "헤라클레스의 머리"

# Name for HIP 91262
msgid "The landing eagle"
msgstr "상륙 독수리"

# Name for HIP 95947
msgid "Beak of the hen"
msgstr "암탉의 부리"

# Name for HIP 102098
msgid "Tail of the hen"
msgstr "암탉의 꼬리"

# Name for HIP 746
msgid "The henna tinted hand"
msgstr "헤나 틴티드 핸드"

# Name for HIP 15863
msgid "Side of Perseus"
msgstr "페르세우스의 측면"

# Name for HIP 14576
msgid "Head of the ogre"
msgstr "오우거의 머리"

# Name for HIP 24608
msgid "Al-Ayyuq"
msgstr "알아유크"

# Name for HIP 86032
msgid "Head of the serpent holder"
msgstr "뱀 홀더의 머리"

# Name for HIP 77070
msgid "Neck of the serpent"
msgstr "뱀의 목"

# Name for HIP 97649
msgid "The flying eagle"
msgstr "나는 독수리"

# Name for HIP 101421
msgid "Tail of the Dolphin"
msgstr "돌고래의 꼬리"

# Name for HIP 677
msgid "Navel of the horse"
msgstr "말의 배꼽"

# Name for HIP 1067
msgid "Wing of the horse"
msgstr "말의 날개"

# Name for HIP 113881
msgid "Shoulder of the horse"
msgstr "말의 어깨"

# Name for HIP 113963
msgid "Rump of the horse"
msgstr "말의 엉덩이"

# Name for HIP 107315
msgid "Mouth of the horse"
msgstr "말의 입"

# Name for HIP 5447
msgid "Abdomen of the fish"
msgstr "물고기의 복부"

# Name for HIP 9640
msgid "Leg of Andromeda"
msgstr "안드로메다의 다리"

# Name for HIP 8796
msgid "Apex of the triangle"
msgstr "삼각형의 정점"

# Name for HIP 9884
msgid "The horn"
msgstr "경적"

# Name for HIP 21421
msgid "The follower"
msgstr "추종자"

# Name for HIP 36850
msgid "Head of the twin"
msgstr "쌍둥이의 머리"

# Name for HIP 49669
msgid "Heart of the lion"
msgstr "사자의 심장"

# Name for HIP 54872
msgid "Back of the lion"
msgstr "사자의 뒷모습"

# Name for HIP 57632
msgid "Tail of the lion"
msgstr "사자 꼬리"

# Name for HIP 80763
msgid "Heart of the scorpion"
msgstr "전갈의 심장"

# Name for HIP 95241
msgid "Heel of the archer"
msgstr "궁수의 발꿈치"

# Name for HIP 107556
msgid "Tail of capricornus"
msgstr "염소자리 꼬리"

# Name for HIP 113368
msgid "Mouth of Piscis Austrinus"
msgstr "물고기자리 오스트리누스의 입"

# Name for HIP 14135
msgid "The leprous hand"
msgstr "문둥병 손"

# Name for HIP 1562
msgid "Tail of Cetus"
msgstr "시터스의 꼬리"

# Name for HIP 24436
msgid "Leg of al-Jawza"
msgstr "알-자자의 다리"

# Name for HIP 13847
msgid "End of the river"
msgstr "강의 끝"

# Name for HIP 32349
msgid "Southern Shi'raa"
msgstr "남부 쉬라"

# Name for HIP 37279
msgid "Northern Shi'raa"
msgstr "북부 쉬라"

# Name for HIP 30438
msgid "Suhayl"
msgstr "수하일"

# Name for HIP 46390
msgid "Al-Fard"
msgstr "알파드"

# Name for HIP 59803
msgid "Right wing of Corvus"
msgstr "코르부스의 오른쪽 날개"

# Name for HIP 65474
msgid "The armless high one"
msgstr "팔이 없는 높은 것"

# Name for HIP 27989
msgid "Shoulder of al-Jawza"
msgstr "알자자의 어깨"

# Name for HIP 71683
msgid "Leg of Centaurus"
msgstr "켄타우로스의 다리"

# Arabic (Ancient) constellation, native: الفرقدان
msgid "The two oryx calves"
msgstr "두 마리의 오릭스 송아지"

# Arabic (Ancient) constellation, native: فأس الرحى
msgid "The axe of the grindstone"
msgstr "숫돌의 도끼"

# Description of Arabic (Ancient) constellation The axe of the grindstone
msgid ""
"Fish shaped two arcs of stars joined at the ends by α UMi and β UMi, named as \n"
"the axe of the grindstone because it revolves around the north stellar pole."
msgstr ""
"물고기 모양의 별 두 개는 끝에서 α UMi와 β UMi로 연결되어 있으며, 북극을 중심으로 회전하기 때문에 숫돌의 도끼라고 합니다."

# Arabic (Ancient) constellation, native: بنات نعش
msgid "Daughters of Na'sh"
msgstr "나쉬의 딸들"

# Description of Arabic (Ancient) constellation Daughters of Na'sh
msgid ""
"The 7 stars of the big dipper, representing 7 girls carrying the bier of their \n"
"father who was killed by Al-Jady (Polaris)."
msgstr "북두칠성의 7개 별은 Al-Jady(Polaris)에게 살해당한 아버지의 영주를 든 7명의 소녀를 나타냅니다."

# Arabic (Ancient) constellation, native: القفزة الأولى
msgid "The first leap"
msgstr "첫 번째 도약"

# Description of Arabic (Ancient) constellation The first leap
msgid ""
"The track of the first leap of the gazelles fleeing the nearby lion, represented \n"
"by the two stars: ν UMa and ξ UMa."
msgstr "ν UMa 및 ξ UMa의 두 별으로 표시된 근처 사자를 피하는 가젤의 첫 번째 도약 경로."

# Arabic (Ancient) constellation, native: القفزة الثانية
msgid "The second leap"
msgstr "두 번째 도약"

# Description of Arabic (Ancient) constellation The second leap
msgid ""
"The track of the second leap of the gazelles represented by the two stars: λ \n"
"UMa and μ UMa."
msgstr "두 개의 별 λ UMa와 μ UMa로 대표되는 가젤의 두 번째 도약의 궤적."

# Arabic (Ancient) constellation, native: القفزة الثالثة
msgid "The third leap"
msgstr "세 번째 도약"

# Description of Arabic (Ancient) constellation The third leap
msgid ""
"The track of the third leap of the gazelles represented by the two stars: ι UMa \n"
"and κ UMa."
msgstr "두 개의 별, ι UMa 및 κ UMa로 대표되는 가젤의 세 번째 도약의 트랙."

# Arabic (Ancient) constellation, native: الظباء وأولاد الظباء
msgid "The Gazelles and their youngsters"
msgstr "가젤과 그 젊은이들"

# Description of Arabic (Ancient) constellation The Gazelles and their
# youngsters
msgid ""
"An area between Ursa Major and Leo, where the brighter stars are the adult \n"
"gazelles, and the faint stars represent the young ones."
msgstr "큰곰자리와 사자자리 사이 영역으로 밝은 별은 성충을, 희미한 별은 어린 가젤을 나타냅니다."

# Arabic (Ancient) constellation, native: الفارطان
msgid "The two preceding to the water"
msgstr "물에 앞서 두"

# Description of Arabic (Ancient) constellation The two preceding to the water
msgid ""
"The two stars: h UMa and υ UMa, representing two men advancing to the water \n"
"pool to fetch water to help dig the grave of Na'sh, father of Daughters of \n"
"Na'sh."
msgstr ""
"두 개의 별: h UMa와 υ UMa는 Na'sh의 딸들의 아버지인 Na'sh의 무덤을 파기 위해 물을 길러 물웅덩이로 나아가는 두 "
"남자를 나타냅니다."

# Arabic (Ancient) constellation, native: الحوض
msgid "The pool"
msgstr "수영장"

# Description of Arabic (Ancient) constellation The pool
msgid ""
"An incomplete circle of stars representing a water pool where the gazelles \n"
"drink, and two men are fetching water."
msgstr "가젤이 물을 마시고 있는 물웅덩이와 두 남자가 물을 길고 있는 모습을 나타내는 불완전한 별 원입니다."

# Arabic (Ancient) constellation, native: أظفار الذئب
msgid "The wolf claws"
msgstr "늑대 발톱"

# Arabic (Ancient) constellation, native: الذئبان
msgid "The two wolves"
msgstr "늑대 두 마리"

# Description of Arabic (Ancient) constellation The two wolves
msgid ""
"The two stars: f Dra and ω Dra, representing two wolves trying to hunt the \n"
"nearby baby camel, the star HR 6618, surrounded by the four mother camels."
msgstr ""
"두 개의 별: f Dra와 ω Dra는 네 마리의 어미 낙타에 둘러싸인 근처의 아기 낙타인 별 HR 6618을 사냥하려는 두 마리의 "
"늑대를 나타냅니다."

# Arabic (Ancient) constellation, native: العوائذ
msgid "The mother camels"
msgstr "어미 낙타"

# Description of Arabic (Ancient) constellation The mother camels
msgid ""
"An irregular square of four stars, representing four mother camels protecting \n"
"the baby camel, the star HR 6618, from the near by Hyena, the star ι Dra, and \n"
"the two wolves."
msgstr ""
"네 개의 별이 불규칙한 사각형으로 네 마리의 어미 낙타가 새끼 낙타를 보호하고, 별 HR 6618이 근처에서 하이에나, 별 드라, 두 "
"마리 늑대를 상징합니다."

# Arabic (Ancient) constellation, native: الأثافي
msgid "The three stone support"
msgstr "세 개의 돌 지지대"

# Description of Arabic (Ancient) constellation The three stone support
msgid ""
"A triangle of three stars representing the stones that are used to hold the \n"
"cooking pot on wood fire."
msgstr "장작불에 냄비를 고정하는 데 사용되는 돌을 나타내는 세 개의 별 삼각형."

# Arabic (Ancient) constellation, native: القدر
msgid "The pot"
msgstr "냄비"

# Description of Arabic (Ancient) constellation The pot
msgid ""
"A circular shape of stars representing a cooking pot near The three stone \n"
"support."
msgstr "세 개의 돌 지지대 근처에 있는 냄비를 나타내는 원형 별 모양."

# Arabic (Ancient) constellation, native: كوكبا الفرق
msgid "The two stars of separation"
msgstr "이별의 두 별"

# Arabic (Ancient) constellation, native: الشاء
msgid "The sheep"
msgstr "그 양"

# Description of Arabic (Ancient) constellation The sheep
msgid ""
"A group of stars representing sheep with the brightest as the shepherd and the \n"
"second brightest as his dog."
msgstr "양을 대표하는 별 무리로 가장 밝은 것은 양치기로, 두 번째로 가장 밝은 것은 그의 개입니다."

# Arabic (Ancient) constellation, native: الرمح
msgid "The spear"
msgstr "창"

# Description of Arabic (Ancient) constellation The spear
msgid "The spear of the armed one."
msgstr "무장한 자의 창."

# Arabic (Ancient) constellation, native: ذو السلاح
msgid "The armed one"
msgstr "무장한 자"

# Description of Arabic (Ancient) constellation The armed one
msgid "The star Arcturus representing a man with a spear."
msgstr "창을 든 남자를 나타내는 별 Arcturus."

# Arabic (Ancient) constellation, native: السماك الأعزل
msgid "The unarmed one"
msgstr "무장하지 않은 자"

# Description of Arabic (Ancient) constellation The unarmed one
msgid ""
"The star Spica representing a man with no arms as opposed to the armed one."
msgstr "무장한 남자와 달리 팔이 없는 남자를 상징하는 스타 스피카."

# Description of Arabic (Ancient) constellation The hyenas and their
# youngsters
msgid ""
"An area where the brighter stars represent the adult hyenas, and the faint ones \n"
"represent the young ones."
msgstr "밝은 별은 성체 하이에나를 나타내고 희미한 별은 어린 하이에나를 나타내는 영역입니다."

# Arabic (Ancient) constellation, native: قصعة المساكين
msgid "The bowl of the poor"
msgstr "가난한 자의 그릇"

# Description of Arabic (Ancient) constellation The bowl of the poor
msgid ""
"The stars of Corona Borealis. The incomplete circle represents a fractured bowl \n"
"of the poor."
msgstr "코로나 보리 얼리스의 별. 불완전한 원은 가난한 사람들의 깨진 그릇을 나타냅니다."

# Arabic (Ancient) constellation, native: النسق الشآمي
msgid "The northern line"
msgstr "북쪽 라인"

# Description of Arabic (Ancient) constellation The northern line
msgid ""
"A group of stars arranged in a line that may represent a line of trees at the \n"
"northern side of the desert garden."
msgstr "사막 정원의 북쪽에 있는 나무의 줄을 나타낼 수 있는 줄로 배열된 별 그룹."

# Arabic (Ancient) constellation, native: النسق اليماني
msgid "The southern line"
msgstr "남쪽 라인"

# Description of Arabic (Ancient) constellation The southern line
msgid ""
"Another group of stars arranged in a line that may represent a line of trees at \n"
"the southern side of the desert garden."
msgstr "사막 정원의 남쪽에 있는 나무 줄을 나타낼 수 있는 줄로 배열된 또 다른 별 그룹."

# Arabic (Ancient) constellation, native: الروضة والأغنام
msgid "The desert garden and the goats"
msgstr "사막의 정원과 염소"

# Description of Arabic (Ancient) constellation The desert garden and the
# goats
msgid ""
"An area of stars representing goats with the brightest stars as the shepherd and \n"
"his two dogs."
msgstr "염소를 나타내는 별 영역과 가장 밝은 별은 양치기와 그의 두 마리입니다."

# Description of Arabic (Ancient) constellation The landing eagle
msgid ""
"The bright star Vega with two nearby stars as his wings forming a triangle."
msgstr "삼각형을 형성하는 날개로 두 개의 가까운 별을 가진 밝은 별 Vega."

# Description of Arabic (Ancient) constellation The flying eagle
msgid "The bright star Altair with a star on each side as his spread wings."
msgstr "날개를 펼친 것처럼 양쪽에 별이 있는 밝은 별 Altair."

# Arabic (Ancient) constellation, native: الفوارس
msgid "The knights"
msgstr "기사들"

# Description of Arabic (Ancient) constellation The knights
msgid ""
"A line of five stars representing five knights with the star the Rear Knight, \n"
"the bright star Deneb, behind them."
msgstr "5명의 기사를 나타내는 5개의 별 라인과 그 뒤에 별 후방 기사, 밝은 별 데네브가 있습니다."

# Arabic (Ancient) constellation, native: رأس الناقة
msgid "The camel head"
msgstr "낙타 머리"

# Arabic (Ancient) constellation, native: عنق الناقة
msgid "The camel neck"
msgstr "낙타 목"

# Arabic (Ancient) constellation, native: يدا الناقة
msgid "The camel front legs"
msgstr "낙타 앞다리"

# Arabic (Ancient) constellation, native: الناقة
msgid "The she-camel"
msgstr "낙타"

# Description of Arabic (Ancient) constellation The she-camel
msgid "A group of stars having a shape of a camel."
msgstr "낙타 모양의 별 무리."

# Description of Arabic (Ancient) constellation The henna tinted hand
msgid "The henna tinted hand of al-Thurayya, the Pleiades."
msgstr "헤나는 플레이아데스인 알-투라야의 손에 착색되었습니다."

# Arabic (Ancient) constellation, native: العاتق
msgid "The shoulder blade"
msgstr "견갑골"

# Description of Arabic (Ancient) constellation The shoulder blade
msgid "The shoulder blade of al-Thurayya, the Pleiades."
msgstr "플레이아데스인 알투라야의 견갑골."

# Arabic (Ancient) constellation, native: المنكب
msgid "The shoulder"
msgstr "어깨"

# Description of Arabic (Ancient) constellation The shoulder
msgid "The shoulder of al-Thurayya, the Pleiades."
msgstr "플레이아데스인 알투라야의 어깨."

# Arabic (Ancient) constellation, native: العضد
msgid "The arm"
msgstr "팔"

# Description of Arabic (Ancient) constellation The arm
msgid "The arm of al-Thurayya, the Pleiades."
msgstr "플레이아데스인 알-투라야의 팔."

# Arabic (Ancient) constellation, native: المرفق
msgid "The elbow"
