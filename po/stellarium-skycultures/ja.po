# Name for NAME Pleiades
msgid "Small Face"
msgstr "小顔"

# Name for NAME Large Magellanic Cloud
msgid "The Running Cloud"
msgstr "走る雲"

# Name for NAME Small Magellanic Cloud
msgid "The Restrained Cloud"
msgstr "拘束された雲"

# Name for NAME Venus
msgid "The Morning Star"
msgstr "明けの明星"

# Name for NAME Venus
msgid "The Evening Star"
msgstr "宵の明星"

