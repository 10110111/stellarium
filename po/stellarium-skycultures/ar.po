msgid "Ogre"
msgstr "‎‎غول‎‎"

# Japanese Lunar Stations constellation, pronounce: HotohoriBoshi
msgid "Stars"
msgstr "‎‎نجوم‎‎"

# Japanese Lunar Stations constellation, pronounce: ChirikoBoshi
msgid "Stretched Net"
