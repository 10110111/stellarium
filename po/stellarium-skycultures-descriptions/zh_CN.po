"\t<td><b>Translation</b> (direct)</td>\n"
"\t<td><b>IAU (Latin) name</b></td>\n"
"\t<td><b>hints to constellation</b></td>\n"
"\t<td><b>freedom of art</b></td>\n"
"</tr>\n"
