"</tr>\n"
"<tr valign=\"top\" style=\"background: #dee6ef\">\n"
"<td>62</td>\n"
"<td>ESTRELLA a la izquierda de la <sup>ESTRELLA</sup><i>ZUQAQ&#298;PU</i>\n"
"(Escorpión): <sup>ESTRELLA</sup><i>URIDIMMU</i></td>\n"
