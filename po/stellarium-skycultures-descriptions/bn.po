"<tr valign=\"top\">\n"
"\t<td><b>সংক্ষিপ্ত নাম</b></td>\n"
"\t<td><b>গ্রীক নাম</b></td>\n"
"\t<td><b>অনুবাদ</b> (সরাসরি)</td>\n"
"\t<td>IAU (ল্যাতিন অর্থ) নাম</td>\n"
"\t<td><b>তারামন্ডলের গঠন</b></td>\n"
"\t<td><b>শৈল্পিক পুনর্গঠন</b></td>\n"
"</tr>\n"
