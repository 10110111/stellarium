"<table cellpadding=\"7\" cellspacing=\"1\">\n"
"<tbody>\n"
"<tr valign=\"top\" style=\"background: #e6e6e6; font-weight: bold\">\n"
"<td width=\"5ex\">constellation number</td>\n"
"<td>asterism</td>\n"
