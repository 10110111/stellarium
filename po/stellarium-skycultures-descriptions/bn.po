"\t<td><notr>&Sigma;&tau;&#941;&phi;&alpha;&nu;&omicron;&sigmaf;</notr></td>\n"
"\t<td>Crown</td>\n"
"\t<td><notr>Corona Borealis</notr></td>\n"
"\t<td>like IAU constellation; no details for lines in the text</td>\n"
"\t<td></td>\n"
