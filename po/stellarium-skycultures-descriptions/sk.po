"\t<td><notr>&Pi;&rho;&omicron;&kappa;&#973;&omega;&nu;</notr></td>\n"
"\t<td>The One before the Dog</td>\n"
"\t<td><notr>Canis Minor</notr></td>\n"
"\t<td></td>\n"
