"<td></td>\n"
"<td><notr>Lup</notr></td>\n"
"</tr>\n"
"<tr valign=\"top\" style=\"background: #dee6ef\">\n"
"<td><notr>63</notr></td>\n"
"<td><sup>STAR</sup><i>ZUQAQ&#298;PU</i></td>\n"
"<td></td>\n"
"<td><notr>Sco</notr></td>\n"
"</tr>\n"
