"\t</tr>\n"
"\t<tr valign=\"top\">\n"
"\t\t<td><notr>UMi</notr></td>\n"
"\t\t<td><notr>&Mu;&iota;&kappa;&rho;&#942; &#702;&#714;&Alpha;&rho;&kappa;&tau;&omicron;&sigmaf;</notr></td>\n"
"\t\t<td>Little She-Bear</td>\n"
"\t\t<td>missing</td>\n"
"\t</tr>\n"
"\t<tr valign=\"top\">\n"
"\t\t<td><notr>UMa</notr></td>\n"
"\t\t<td><notr>&Mu;&epsilon;&gamma;&alpha;&lambda;&#942; &#702;&#714;&Alpha;&rho;&kappa;&tau;&omicron;&sigmaf;</notr></td>\n"
"\t\t<td>Great She-Bear</td>\n"
"\t\t<td>missing</td>\n"
"\t</tr>\n"
"\t<tr valign=\"top\">\n"
"\t\t<td><notr>Dra</notr></td>\n"
"\t\t<td><notr>&Delta;&rho;&#940;&kappa;&omega;&nu;</notr></td>\n"
"\t\t<td>Dragon</td>\n"
"\t\t<td>only the head and one bend are depicted<br /><img width=\"255\" src=\"dra_sw_bg.png\"/></td>\n"
"\t</tr>\n"
