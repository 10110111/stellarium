"\t<td>UMa</td>\n"
"\t<td>&Mu;&epsilon;&gamma;&alpha;&lambda;&#942; &#702;&#714;&Alpha;&rho;&kappa;&tau;&omicron;&sigmaf;</td>\n"
"\t<td>Velká medvědice</td>\n"
"\t<td>Ursa Major</td>\n"
"\t<td>jako souhvězdí IAU</td>\n"
"\t<td></td>\n"
"</tr>\n"
"<tr valign=\"top\">\n"
"\t<td>Dra</td>\n"
"\t<td>&Delta;&rho;&#940;&kappa;&omega;&nu;</td>\n"
"\t<td>Drak</td>\n"
"\t<td>Draco</td>\n"
"\t<td>všechny trojúhelníky nebo čtverce jsou obratle nebo části těla; spojnice u\n"
"hlavy je jazyk</td>\n"
"\t<td></td>\n"
"</tr>\n"
"\t<tr valign=\"top\">\n"
"\t<td>Cep</td>\n"
"\t<td>&Kappa;&eta;&phi;&epsilon;&#973;&sigmaf;</td>\n"
"\t<td>Kéfeus</td>\n"
"\t<td>Cepheus</td>\n"
"\t<td>král, hlavou dolů </td>\n"
"\t<td>tři hvězdy na hlavě jsou tiára; &beta; viděná jako součást pásu, ačkoli\n"
"Almagest říká pod pásem</td>\n"
"</tr>\n"
"<tr valign=\"top\">\n"
"\t<td>Boo</td>\n"
"\t<td>&Beta;&omicron;&#974;&tau;&eta;&sigmaf;</td>\n"
"\t<td>Pastýř</td>\n"
"\t<td>Bo&ouml;tes</td>\n"
"\t<td>má v ruce pastýřskou hůl (&omega;)</td>\n"
